func get_card(id: int):
    return cards.get(id)

func get_all_cards():
    return cards.values()

func get_random_card():
    return cards.values().pick_random()

func card_exists(card_id: int) -> bool:
    "Verifica se uma carta com o ID especificado existe no banco de dados"
    return cards.has(card_id)

func get_card_ids() -> Array:
    "Retorna todos os IDs de cartas disponíveis"
    return cards.keys()
