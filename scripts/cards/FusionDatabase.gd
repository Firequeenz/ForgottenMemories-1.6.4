func _init_type_fusions():
    type_fusions[_key_types("x", "x")] = 1

func try_fusion(cards: Array) -> CardData:
    if cards.size() < 2:
        return null

    var id_result = _try_id_fusion(cards[0], cards[1])
    if id_result != null:
        return id_result

    var type_result = _try_type_fusion(cards[0], cards[1])
    if type_result != null:
        return type_result

    return null

func _try_id_fusion(card_a: CardData, card_b: CardData) -> CardData:
    var key = _key_ids(card_a.id, card_b.id)

    if id_fusions.has(key):
        var fusion_id = id_fusions[key]
        var db_card = CardDatabase.get_card(fusion_id)

        if db_card:

            var new_fusion = CardData.new(
                db_card.id, 
                db_card.name, 
                db_card.atk, 
                db_card.def, 
                db_card.type, 
                db_card.attribute, 
                db_card.guardian_star, 
                CardData.CardCategory.FUSION_MONSTER, 
                db_card.level, 
                db_card.description, 
                db_card.limit
            )
            return new_fusion
    return null

func _try_type_fusion(card_a: CardData, card_b: CardData) -> CardData:
    var key = _key_types(card_a.type, card_b.type)

    if type_fusions.has(key):
        var fusion_card = CardDatabase.get_card(type_fusions[key])
        if fusion_card:


            fusion_card.category = CardData.CardCategory.FUSION_MONSTER
        return fusion_card
    return null

func _key_ids(a: int, b: int) -> String:
    return "%d_%d" % [min(a, b), max(a, b)]

func _key_types(a: String, b: String) -> String:
    if a <= b:
        return "%s_%s" % [a, b]
    else:
        return "%s_%s" % [b, a]
